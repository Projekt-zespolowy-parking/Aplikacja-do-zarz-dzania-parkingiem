generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Rola {
  ADMIN
  PROWADZACY
  STUDENT
}

enum StatusMiejsca {
  WOLNY
  ZAJETY
  ZAREZERWOWANY
}

enum TypMiejsca {
  STANDARD
  DLA_PROWADZACEGO
  NIEPELNOSPRAWNY
}

model User {
  id           Int           @id @default(autoincrement())
  imie          String
  email         String        @unique
  haslo         String
  rola          Rola          @default(STUDENT)
  reservations  Reservation[]
  createdAt     DateTime      @default(now())
}

model ParkingSpot {
  id           Int             @id @default(autoincrement())
  numer        String          @unique
  poziom       Int
  typ          TypMiejsca
  status       StatusMiejsca   @default(WOLNY)
  reservations Reservation[]
}

model Reservation {
  id            Int           @id @default(autoincrement())
  userId        Int
  parkingSpotId Int
  dataOd        DateTime
  dataDo        DateTime

  user          User          @relation(fields: [userId], references: [id])
  parkingSpot   ParkingSpot   @relation(fields: [parkingSpotId], references: [id])

  createdAt     DateTime      @default(now())
}